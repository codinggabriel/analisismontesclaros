</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-text fade-up">
    <div class="hero-eyebrow">Informe Profesional · Marzo 2026</div>
    <h1>Calle de los<br>Pozos, <em>25</em></h1>
    <p class="hero-sub">
      <strong>Montesclaros · Toledo · Sierra de San Vicente</strong><br>
      Valoración profesional con datos reales de mercado. 135 m² · 3 habitaciones · 3 baños · Piscina privada · Jardín · <strong>Estado: a reformar.</strong>
    </p>
    <a href="#veredicto" class="btn-primary">Ver veredicto final →</a>
    <a href="#comparables" class="btn-secondary">Comparables</a>
  </div>

  <div class="hero-visual fade-up" style="transition-delay:.15s">
    <div class="hero-card">
      <div class="hero-card-label">
        Ficha del activo
        <span class="pill-status">A reformar</span>
      </div>
      <div class="metric-grid">
