<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Informe Inmobiliario · Calle de los Pozos 25 · Montesclaros</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,700;0,800;0,900;1,700&family=Lora:ital,wght@0,400;0,500;1,400;1,500&family=Playfair+Display:ital,wght@0,400;1,400;1,600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
:root {
  --bg:    #F7F4EF;
  --bg2:   #EDEAE3;
  --ink:   #0D1B2A;
  --red:   #C41E3A;
  --navy:  #1B3354;
  --gold:  #B8933A;
  --muted: rgba(13,27,42,.5);
  --line:  rgba(13,27,42,.1);
  --white: #FFFFFF;
  --rl:    rgba(196,30,58,.06);
  --rm:    rgba(196,30,58,.13);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--ink);
  font-family: 'Lora', Georgia, serif;
  font-size: 1rem;
  line-height: 1.88;
  -webkit-font-smoothing: antialiased;
}

/* ── NAV ── */
nav {
  position: fixed;
  top: 1.2rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 100;
  background: rgba(247,244,239,.82);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--line);
  border-radius: 999px;
  padding: .6rem 1.6rem;
  display: flex;
  gap: 2.2rem;
  align-items: center;
  font-family: 'DM Mono', monospace;
  font-size: .58rem;
  letter-spacing: .2em;
  text-transform: uppercase;
  transition: box-shadow .3s;
}
nav.scrolled { box-shadow: 0 4px 32px rgba(13,27,42,.12); }
nav a { color: var(--muted); text-decoration: none; transition: color .2s; }
nav a:hover { color: var(--red); }
nav .nav-brand { color: var(--ink); font-weight: 500; }

/* ── CONTENEDOR ── */
.wrap { width: min(920px, 92vw); margin: 0 auto; }

/* ── HERO ── */
.hero {
  min-height: 100svh;
  display: grid;
  grid-template-columns: 1.1fr .9fr;
  gap: 5rem;
  align-items: center;
  padding: 9rem 6vw 6rem;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '2026';
  position: absolute;
  bottom: -2rem;
  right: -1rem;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: clamp(10rem, 22vw, 20rem);
  font-weight: 900;
  color: var(--ink);
  opacity: .028;
  line-height: 1;
  pointer-events: none;
  user-select: none;
}
/* Grid background */
.hero::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(var(--line) 1px, transparent 1px),
    linear-gradient(90deg, var(--line) 1px, transparent 1px);
  background-size: 60px 60px;
  -webkit-mask-image: radial-gradient(ellipse 70% 80% at 50% 50%, black 30%, transparent 100%);
  mask-image: radial-gradient(ellipse 70% 80% at 50% 50%, black 30%, transparent 100%);
  pointer-events: none;
}
.hero-text { position: relative; z-index: 2; }
.hero-eyebrow {
  font-family: 'DM Mono', monospace;
  font-size: .58rem;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 1.2rem;
  display: flex;
  align-items: center;
  gap: .7rem;
}
.hero-eyebrow::before {
  content: '';
  display: inline-block;
  width: 2rem;
  height: 1px;
  background: var(--red);
}
h1 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: clamp(3.6rem, 8vw, 7.8rem);
  font-weight: 900;
  line-height: .93;
  letter-spacing: -.01em;
  text-transform: uppercase;
  color: var(--ink);
  margin-bottom: 1.8rem;
}
h1 em { font-style: italic; color: var(--red); }
.hero-sub {
  font-family: 'Lora', serif;
  font-size: .95rem;
  color: var(--muted);
  line-height: 1.85;
  max-width: 38ch;
  margin-bottom: 2.5rem;
}
.hero-sub strong { color: var(--ink); }
.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: .6rem;
  background: var(--red);
  color: var(--white);
  font-family: 'DM Mono', monospace;
  font-size: .6rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  text-decoration: none;
  padding: .9rem 1.8rem;
  border-radius: 4px;
  transition: all .22s;
}
.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(196,30,58,.35); }
.btn-secondary {
  display: inline-flex;
  align-items: center;
  gap: .6rem;
  background: transparent;
  color: var(--ink);
  font-family: 'DM Mono', monospace;
  font-size: .6rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  text-decoration: none;
  padding: .9rem 1.4rem;
  border: 1px solid var(--line);
  border-radius: 4px;
  margin-left: .8rem;
  transition: all .22s;
}
.btn-secondary:hover { border-color: var(--ink); }
.hero-visual { position: relative; z-index: 2; }
.hero-card {
  background: var(--white);
  border-radius: 4px;
  padding: 2.2rem;
  box-shadow:
    8px 8px 0 var(--rm),
    16px 16px 0 rgba(196,30,58,.05),
    0 0 60px rgba(196,30,58,.08);
  border: 1px solid var(--line);
}
.hero-card-label {
  font-family: 'DM Mono', monospace;
  font-size: .55rem;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1.4rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.pill-status {
  background: var(--rl);
  border: 1px solid var(--rm);
  color: var(--red);
  padding: .2rem .7rem;
  border-radius: 999px;
  font-size: .55rem;
  letter-spacing: .15em;
}
.metric-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: var(--line);
  margin-bottom: 1px;
}
.metric {
  background: var(--bg);
  padding: 1.1rem .9rem;
  display: flex;
  flex-direction: column;
  gap: .3rem;
}
.metric-val {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.7rem;
  font-weight: 800;
  line-height: 1;
  color: var(--ink);
}
.metric-val.red { color: var(--red); }
.metric-val.gold { color: var(--gold); }
.metric-lbl {
  font-family: 'DM Mono', monospace;
  font-size: .52rem;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--muted);
}
.verdict-strip {
  background: var(--ink);
  color: var(--white);
  padding: 1rem 1.2rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-radius: 0 0 4px 4px;
}
.verdict-label {
  font-family: 'DM Mono', monospace;
  font-size: .55rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: rgba(255,255,255,.5);
}
.verdict-val {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.3rem;
  font-weight: 800;
  letter-spacing: .02em;
  text-transform: uppercase;
  color: var(--gold);
}

/* ── DIVISOR ── */
.divider {
  width: 100%;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--red), transparent);
  margin: 5rem 0;
  opacity: .35;
}

/* ── SECCIÓN GENÉRICA ── */
section { padding: 5.5rem 0; }
.section-tag {
  font-family: 'DM Mono', monospace;
  font-size: .56rem;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: .8rem;
  display: flex;
  align-items: center;
  gap: .6rem;
}
.section-tag::before {
  content: '';
  display: inline-block;
  width: 1.5rem;
  height: 1px;
  background: var(--red);
}
h2 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: clamp(2.4rem, 5vw, 4.4rem);
  font-weight: 800;
  line-height: .95;
  letter-spacing: -.01em;
  text-transform: uppercase;
  color: var(--ink);
  margin-bottom: 2.5rem;
}
h2 em { color: var(--red); font-style: italic; }
h3 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.5rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .02em;
  color: var(--ink);
  margin-bottom: 1rem;
}
p { color: var(--muted); font-size: .95rem; line-height: 1.88; margin-bottom: 1rem; }
p strong { color: var(--ink); font-weight: 500; }
.lede { font-size: 1.05rem; color: var(--ink); font-weight: 500; line-height: 1.8; }

/* ── PULL QUOTE ── */
.pull {
  border-left: 3px solid var(--red);
  padding: 1.2rem 1.8rem;
  margin: 2rem 0;
  background: var(--rl);
  border-radius: 0 4px 4px 0;
}
.pull p {
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-size: 1.05rem;
  color: var(--ink);
  margin: 0;
  line-height: 1.7;
}

/* ── STAT BAND ── */
.stat-band {
  background: var(--ink);
  border-radius: 4px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  overflow: hidden;
  margin: 3rem 0;
}
.stat-item {
  padding: 2rem 1.5rem;
  border-right: 1px solid rgba(255,255,255,.08);
  display: flex;
  flex-direction: column;
  gap: .4rem;
}
.stat-item:last-child { border-right: none; }
.stat-num {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 2.8rem;
  font-weight: 900;
  line-height: 1;
  color: var(--white);
}
.stat-num.accent { color: var(--gold); }
.stat-num.red { color: var(--red); }
.stat-desc {
  font-family: 'DM Mono', monospace;
  font-size: .53rem;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: rgba(255,255,255,.45);
  line-height: 1.5;
}
.stat-source {
  font-family: 'DM Mono', monospace;
  font-size: .48rem;
  letter-spacing: .1em;
  color: rgba(255,255,255,.22);
  margin-top: .4rem;
}

/* ── CARDS GRID ── */
.cards { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin: 2rem 0; }
.cards.three { grid-template-columns: 1fr 1fr 1fr; }
.card {
  background: var(--white);
  border: 1px solid var(--line);
  border-radius: 4px;
  padding: 2rem;
  transition: all .25s;
}
.card:hover { transform: translateY(-3px); box-shadow: 0 12px 36px rgba(13,27,42,.1); }
.card-tag {
  font-family: 'DM Mono', monospace;
  font-size: .52rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: .8rem;
}
.card h3 { font-size: 1.15rem; margin-bottom: .6rem; }
.card p { font-size: .88rem; margin: 0; line-height: 1.75; }
.card .card-num {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 2.2rem;
  font-weight: 800;
  color: var(--red);
  line-height: 1;
  margin-bottom: .4rem;
}
.card.dark { background: var(--ink); border-color: transparent; }
.card.dark h3 { color: var(--white); }
.card.dark p { color: rgba(255,255,255,.5); }
.card.dark .card-tag { color: var(--gold); }
.card.dark .card-num { color: var(--gold); }

/* ── TABLA COMPARABLES ── */
.table-wrap { overflow-x: auto; margin: 2rem 0; }
table { width: 100%; border-collapse: collapse; }
thead tr {
  background: var(--ink);
}
thead th {
  padding: .9rem 1rem;
  font-family: 'DM Mono', monospace;
  font-size: .52rem;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: rgba(255,255,255,.6);
  text-align: left;
  font-weight: 400;
}
tbody tr { border-bottom: 1px solid var(--line); transition: background .15s; }
tbody tr:hover { background: var(--bg2); }
tbody tr.highlight { background: rgba(184,147,58,.07); border-bottom: 1px solid rgba(184,147,58,.25); }
tbody tr.highlight td { color: var(--ink); font-weight: 500; }
td {
  padding: .85rem 1rem;
  font-size: .88rem;
  color: var(--muted);
  font-family: 'Lora', serif;
}
td.mono {
  font-family: 'DM Mono', monospace;
  font-size: .78rem;
  color: var(--ink);
}
td .badge {
  display: inline-block;
  padding: .15rem .6rem;
  border-radius: 999px;
  font-family: 'DM Mono', monospace;
  font-size: .5rem;
  letter-spacing: .12em;
  text-transform: uppercase;
}
.badge.ok { background: rgba(40,167,69,.1); color: #1a7a32; border: 1px solid rgba(40,167,69,.25); }
.badge.warn { background: rgba(255,179,0,.1); color: #8a5e00; border: 1px solid rgba(255,179,0,.3); }
.badge.bad { background: var(--rl); color: var(--red); border: 1px solid var(--rm); }
.badge.act { background: rgba(184,147,58,.12); color: var(--gold); border: 1px solid rgba(184,147,58,.3); }

/* ── CHART BARS ── */
.chart { margin: 2.5rem 0; }
.chart-title {
  font-family: 'DM Mono', monospace;
  font-size: .55rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 1.5rem;
  padding-bottom: .6rem;
  border-bottom: 1px solid var(--line);
}
.bar-row { display: flex; align-items: center; gap: 1rem; margin-bottom: .9rem; }
.bar-lbl {
  font-family: 'DM Mono', monospace;
  font-size: .55rem;
  letter-spacing: .1em;
  color: var(--muted);
  width: 18ch;
  flex-shrink: 0;
  text-align: right;
}
.bar-track { flex: 1; background: var(--bg2); border-radius: 2px; height: 10px; overflow: hidden; }
.bar-fill {
  height: 100%;
  border-radius: 2px;
  transition: width 1s cubic-bezier(.16,1,.3,1);
}
.bar-val {
  font-family: 'DM Mono', monospace;
  font-size: .58rem;
  color: var(--ink);
  width: 7ch;
  flex-shrink: 0;
  font-weight: 500;
}

/* ── RANGO DE PRECIO ── */
.price-range { margin: 2.5rem 0; position: relative; }
.range-track {
  height: 8px;
  background: var(--bg2);
  border-radius: 4px;
  position: relative;
  margin: 2.5rem 0 3rem;
}
.range-zone {
  position: absolute;
  height: 100%;
  border-radius: 4px;
}
.range-tick {
  position: absolute;
  top: -2px;
  height: 12px;
  width: 2px;
  transform: translateX(-50%);
}
.range-tick-lbl {
  position: absolute;
  top: -20px;
  transform: translateX(-50%);
  font-family: 'DM Mono', monospace;
  font-size: .5rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  white-space: nowrap;
}
.range-tick-val {
  position: absolute;
  bottom: -22px;
  transform: translateX(-50%);
  font-family: 'DM Mono', monospace;
  font-size: .55rem;
  font-weight: 500;
  white-space: nowrap;
}

/* ── RISK MATRIX ── */
.risk-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; margin: 2rem 0; }
.risk-item {
  background: var(--white);
  border: 1px solid var(--line);
  border-radius: 4px;
  padding: 1.4rem 1.6rem;
}
.risk-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: .8rem; }
.risk-name {
  font-family: 'DM Mono', monospace;
  font-size: .56rem;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--ink);
}
.risk-score {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.2rem;
  font-weight: 800;
  line-height: 1;
}
.risk-bar { height: 4px; background: var(--bg2); border-radius: 2px; }
.risk-bar-fill { height: 100%; border-radius: 2px; }
.risk-note { font-size: .8rem; margin-top: .5rem; margin-bottom: 0; line-height: 1.6; }

/* ── NEGOCIACIÓN ── */
.nego-table { margin: 2rem 0; }
.nego-row {
  display: grid;
  grid-template-columns: 1.2fr .7fr 1fr 1fr 1.2fr;
  border-bottom: 1px solid var(--line);
  transition: background .15s;
}
.nego-row:hover { background: var(--bg2); }
.nego-row.head { background: var(--ink); border: none; }
.nego-cell {
  padding: .85rem 1rem;
  font-size: .85rem;
  color: var(--muted);
  font-family: 'Lora', serif;
  display: flex;
  align-items: center;
}
.nego-row.head .nego-cell {
  font-family: 'DM Mono', monospace;
  font-size: .5rem;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: rgba(255,255,255,.5);
}

/* ── INVERSIÓN ── */
.inv-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; border: 1px solid var(--line); border-radius: 4px; overflow: hidden; margin: 2rem 0; }
.inv-col { border-right: 1px solid var(--line); }
.inv-col:last-child { border-right: none; }
.inv-col-head {
  padding: 1.2rem 1.4rem;
  background: var(--bg2);
  font-family: 'DM Mono', monospace;
  font-size: .55rem;
  letter-spacing: .16em;
  text-transform: uppercase;
}
.inv-col-head.conserv { color: var(--muted); }
.inv-col-head.base { background: var(--navy); color: rgba(255,255,255,.7); }
.inv-col-head.optim { background: var(--ink); color: var(--gold); }
.inv-row { border-top: 1px solid var(--line); }
.inv-cell {
  padding: .75rem 1.4rem;
  font-size: .85rem;
  color: var(--muted);
}
.inv-cell.row-lbl {
  font-family: 'DM Mono', monospace;
  font-size: .54rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--muted);
}
.inv-cell.bold { font-weight: 500; color: var(--ink); font-family: 'Lora', serif; }
.inv-cell.highlight-gold { color: var(--gold); font-weight: 500; font-family: 'Barlow Condensed', sans-serif; font-size: 1.1rem; letter-spacing: .02em; }
.inv-cell.highlight-green { color: #1a7a32; font-weight: 500; font-family: 'Barlow Condensed', sans-serif; font-size: 1.1rem; }
.inv-lbl-col { background: var(--bg); border-right: 1px solid var(--line); }

/* ── VEREDICTO FINAL ── */
.verdict-block {
  background: var(--ink);
  border-radius: 4px;
  padding: 4rem 3.5rem;
  position: relative;
  overflow: hidden;
  margin: 3rem 0;
}
.verdict-block::before {
  content: 'NEGOCIAR';
  position: absolute;
  bottom: -3rem;
  right: -1rem;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: clamp(8rem, 20vw, 16rem);
  font-weight: 900;
  color: rgba(255,255,255,.025);
  line-height: 1;
  pointer-events: none;
}
.verdict-tag {
  font-family: 'DM Mono', monospace;
  font-size: .56rem;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1rem;
  display: flex;
  align-items: center;
  gap: .6rem;
}
.verdict-tag::before { content: ''; display: inline-block; width: 1.5rem; height: 1px; background: var(--gold); }
.verdict-headline {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: clamp(3rem, 7vw, 6rem);
  font-weight: 900;
  text-transform: uppercase;
  line-height: .95;
  color: var(--white);
  margin-bottom: 2.5rem;
}
.verdict-headline em { color: var(--gold); font-style: italic; }
.verdict-metrics { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: rgba(255,255,255,.08); margin-top: 2.5rem; }
.vm {
  padding: 1.8rem 1.5rem;
  background: rgba(255,255,255,.04);
  display: flex;
  flex-direction: column;
  gap: .4rem;
}
.vm-num { font-family: 'Barlow Condensed', sans-serif; font-size: 2.2rem; font-weight: 900; color: var(--gold); line-height: 1; }
.vm-lbl { font-family: 'DM Mono', monospace; font-size: .52rem; letter-spacing: .16em; text-transform: uppercase; color: rgba(255,255,255,.35); }
.vm-note { font-size: .8rem; color: rgba(255,255,255,.35); font-family: 'Lora', serif; line-height: 1.5; }

/* ── CONCLUSIONES ── */
.conclusion-list { margin: 2rem 0; }
.conclusion-item {
  display: grid;
  grid-template-columns: 3rem 1fr;
  gap: 1.2rem;
  padding: 1.5rem 0;
  border-bottom: 1px solid var(--line);
  align-items: start;
}
.conclusion-item:last-child { border-bottom: none; }
.conclusion-icon {
  font-size: 1.5rem;
  padding-top: .1rem;
}
.conclusion-item h3 { font-size: 1.1rem; margin-bottom: .4rem; }
.conclusion-item p { font-size: .9rem; margin: 0; }

/* ── FUENTES ── */
.sources {
  background: var(--bg2);
  border-radius: 4px;
  padding: 1.8rem 2rem;
  margin: 3rem 0;
}
.sources-title {
  font-family: 'DM Mono', monospace;
  font-size: .56rem;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 1rem;
}
.sources-list {
  display: flex;
  flex-wrap: wrap;
  gap: .6rem;
}
.source-pill {
  background: var(--white);
  border: 1px solid var(--line);
  border-radius: 999px;
  padding: .3rem .9rem;
  font-family: 'DM Mono', monospace;
  font-size: .52rem;
  letter-spacing: .12em;
  color: var(--muted);
}

/* ── FOOTER ── */
footer {
  border-top: 1px solid var(--line);
  padding: 2.5rem 0;
  text-align: center;
}
footer p {
  font-family: 'DM Mono', monospace;
  font-size: .52rem;
  letter-spacing: .12em;
  color: var(--muted);
  margin: 0;
  line-height: 1.8;
}

/* ── SCROLL ANIMATIONS ── */
.fade-up { opacity: 0; transform: translateY(28px); transition: opacity .7s ease, transform .7s ease; }
.fade-up.vis { opacity: 1; transform: translateY(0); }

@media (max-width: 720px) {
  .hero { grid-template-columns: 1fr; padding: 7rem 5vw 4rem; gap: 3rem; }
  .hero::before { display: none; }
  .stat-band { grid-template-columns: 1fr 1fr; }
  .cards, .cards.three { grid-template-columns: 1fr; }
  .risk-grid { grid-template-columns: 1fr; }
  .inv-grid { grid-template-columns: 1fr; }
  .verdict-metrics { grid-template-columns: 1fr; }
  .nego-row { grid-template-columns: 1fr; }
  .nego-row.head { display: none; }
}
</style>
</head>

<body>

